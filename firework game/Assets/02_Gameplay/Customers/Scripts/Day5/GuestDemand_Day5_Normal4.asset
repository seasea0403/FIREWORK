  guestName: "\u7518\u662D"
  demandDesc: "\u54B1\u5BB6\u5949\u65E8\u524D\u6765\u3002\u660E\u65E5\u5BAB\u4E2D\u5927\u5BB4\uFF0C\u5723\u4EBA\u8981\u4E0E\u6C11\u540C\u4E50\u89C2\u8D4F\u70DF\u706B\uFF0C\u6B63\u5408\u7A3C\u8F69\u8BCD\u4E2D\u76DB\u666F\u3002\u5C14\u7B49\u9700\u62FF\u51FA\u770B\u5BB6\u672C\u9886\uFF0C\u5236\u4E00\u679A\u6700\u7CBE\u5999\u7EDD\u4F26\u7684\u3002\u8981\u80FD\u4E0A\u5929\uFF0C\u5916\u5934\u8FD8\u5F97\u7528\u9802\u597D\u7684\u5F69\u7EB8\u88F9\u7740\uFF01\u91CC\u5934\u673A\u5173\u3001\u82B1\u8272\uFF0C\u4E00\u6837\u90FD\u9A6C\u864E\u4E0D\u5F97\uFF01"
  perfectMoney: 100
  goodMoney: 60
  failMoney: 20
  timeoutMoney: 0
  perfectText: "\u795E\u4E4E\u5176\u6280\uFF01\u6BD4\u67D0\u60F3\u7684\u8FD8\u8981\u597D\uFF0C\u4E0B\u56DE\u5B9A\u5F53\u518D\u6765\u5149\u987E\uFF01"
  goodText: "\u5C1A\u53EF\u5C1A\u53EF\uFF0C\u52C9\u5F3A\u5408\u67D0\u5FC3\u610F\uFF0C\u8D4F\u4F60\u4E9B\u788E\u94F6\uFF01"
  failText: "\u8D27\u4E0D\u5BF9\u677F\uFF01\u8FD9\u822C\u624B\u827A\u4E5F\u6562\u51FA\u6765\u505A\u751F\u610F\uFF1F\u6263\u94B1\uFF01"
  timeoutText: "\u8FD9\u2026\u2026\u505A\u5F97\u4E5F\u592A\u6162\u4E86\uFF0C\u67D0\u53BB\u522B\u5BB6\u770B\u770B\u3002"
