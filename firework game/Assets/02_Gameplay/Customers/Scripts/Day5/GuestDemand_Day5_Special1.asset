  guestName: "\u5E03\u59E5\u59E5"
  demandDesc: "\u638C\u67DC\u7684\uFF0C\u8001\u8EAB\u8FD9\u53A2\u8D3A\u559C\u4E86\u3002\u65B0\u6625\u6700\u540E\u4E00\u5929\uFF0C\u5E03\u5E84\u60F3\u653E\u4E2A\u5927\u7206\u4ED7\uFF0C\u8981\u53C8\u54CD\u53C8\u4EAE\uFF0C\u5E26\u7740\u7EA2\u7EFF\u5F69\u5B50\u7684\uFF0C\u56FE\u4E2A\u5F00\u5E74\u5927\u5409\uFF0C\u65B0\u5E03\u7545\u9500\u3002"
  perfectMoney: 200
  goodMoney: 120
