  demandDesc: "\u5C0F\u751F\u8FD9\u53A2\u6709\u793C\u4E86\u3002\u6562\u95EE\u638C\u67DC\uFF0C\u53EF\u6709\u4E03\u5915\u80FD\u653E\u7684\u70DF\u82B1\uFF1F\u5F85\u5230\u91D1\u98CE\u7389\u9732\u65F6\uFF0C\u5C0F\u751F\u60F3\u9001\u4E0E\u5FC3\u4E0A\u4EBA\uFF0C\u6548\u4EFF\u725B\u90CE\u7EC7\u5973\u4E4B\u610F\u3002"
