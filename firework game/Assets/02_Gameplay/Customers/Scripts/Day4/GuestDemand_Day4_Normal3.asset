  demandDesc: "\u6211\u8981\u4E00\u4E2A\u80FD\u5728\u5730\u4E0A\u54CD\u4E24\u56DE\u7684\uFF01\u7B2C\u4E00\u4E0B\u8981\u8F7B\uFF0C\u50CF\u7092\u8C46\u5B50\uFF1B\u7B2C\u4E8C\u4E0B\u8981\u9707\u5929\u54CD\uFF0C\u50CF\u6253\u96F7\uFF01\u522B\u7684\u968F\u4FBF\u3002"
