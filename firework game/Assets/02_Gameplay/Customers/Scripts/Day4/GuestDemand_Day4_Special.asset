  timeoutMoney: 0
  perfectText: "\u5999\u54C9\uFF01\u5982\u5979\u89C1\u4E86\uFF0C\u63A9\u9762\u800C\u7B11\uFF0C\u5C0F\u751F\u5FC3\u613F\u8DB3\u77E3\u3002"
  goodText: "\u5C1A\u53EF\u5C1A\u53EF\uFF0C\u52C9\u5F3A\u5408\u67D0\u5FC3\u610F\uFF0C\u8D4F\u4F60\u4E9B\u788E\u94F6\uFF01"
  failText: "\u8FD9\u2026\u2026\u600E\u7684\u53EA\u8E7F\u4E0A\u534A\u7A7A\u5C31\u6563\u4E86\uFF1F\u989C\u8272\u4E5F\u9EEF\u6DE1\uFF0C\u5012\u6559\u5C0F\u751F\u5728\u90A3\u6865\u4E0A\u7AD9\u4E86\u597D\u5927\u4E00\u4E2A\u6CA1\u8DA3\u3002"
  timeoutText: "\u8FD9\u2026\u2026\u505A\u5F97\u4E5F\u592A\u6162\u4E86\uFF0C\u67D0\u53BB\u522B\u5BB6\u770B\u770B\u3002"
