  guestName: "\u7518\u662D"
  demandDesc: "\u671D\u5949\u6709\u793C\u3002\u524D\u65E5\u4E0B\u4E61\u5DE1\u89C6\uFF0C\u591C\u5BBF\u5C71\u5BFA\uFF0C\u5FFD\u95FB\u602A\u5F02\u4E4B\u58F0\uFF0C\u6405\u5F97\u672C\u5B98\u5F7B\u591C\u96BE\u7720\uFF0C\u7740\u5B9E\u53EF\u607C\u3002\u542C\u95FB\u8D35\u5E97\u70DF\u706B\u66FE\u60CA\u9000\u5C71\u9B48\uFF0C\u7279\u6765\u76F8\u6C42\u3002"
  perfectMoney: 200
  goodMoney: 120
