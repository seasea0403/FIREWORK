  demandDesc: "\u613F\u6211\u5982\u661F\u541B\u5982\u6708\uFF0C\u591C\u591C\u6D41\u5149\u76F8\u768E\u6D01\u3002\u60F3\u4E70\u4E2A\u70DF\u82B1\u9001\u4EBA\uFF0C\u4E0D\u77E5\u53EF\u6709\u6A21\u6837\u7A00\u5947\u4E9B\u7684\u2026\u2026\u50CF\u4E2A\u2026\u2026\u50CF\u4E2A\u5E76\u8482\u83B2\uFF1F\u6216\u8005\u2026\u2026\u5FC3\u6709\u7075\u7280\u4E00\u70B9\u901A"
