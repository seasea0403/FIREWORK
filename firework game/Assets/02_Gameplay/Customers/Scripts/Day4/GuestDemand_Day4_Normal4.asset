  demandDesc: "\u67D0\u5BB6\u884C\u8D70\u6C5F\u6E56\uFF0C\u60F3\u5907\u4E9B\u9632\u8EAB\u4E4B\u7269\u3002\u80FD\u5426\u5C06\u70DF\u82B1\u505A\u5F97\u5C0F\u5DE7\u5982\u98DE\u9556\uFF0C\u624B\u63B7\u5373\u70B8\uFF1F\u53EF\u5343\u4E07\u522B\u52A0\u9694\u677F\uFF0C\u5C31\u8981\u90A3\u4E00\u4E0B\u5B50\u8FF8\u53D1\u7684\u3002"
