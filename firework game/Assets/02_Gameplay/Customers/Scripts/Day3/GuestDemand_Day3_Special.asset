  guestName: "\u82F1\u5A25&\u677E\u54E5\u513F"
  demandDesc: "\u638C\u67DC\u4E07\u798F\uFF01\u6211\u5BB6\u677E\u54E5\u513F\u8FD9\u51E0\u65E5\u602A\u5F97\u5F88\uFF0C\u767D\u65E5\u91CC\u6D3B\u8E66\u4E71\u8DF3\uFF0C\u4E00\u5230\u591C\u91CC\u5C31\u53D1\u70E7\uFF0C\u533B\u9986\u7684\u5927\u592B\u77A7\u4E86\u51E0\u65E5\u4E5F\u4E0D\u89C1\u597D\u3002\u53C8\u542C\u95FB\u5B98\u5E9C\u7981\u4EE4\uFF0C\u5FC3\u4E2D\u603B\u5F52\u6709\u4E9B\u4E0D\u592A\u5E73\u3002"
  perfectMoney: 200
  goodMoney: 120
